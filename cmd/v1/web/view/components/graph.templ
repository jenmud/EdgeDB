package components

import (
    "fmt"
) 


templ GraphContainer(apiQuery string) {
   <div id="graph-container" data-init={ fmt.Sprintf(`MakeGraph("graph-container", "%s")`, apiQuery) }></div>
}

templ Graph() {
    <div data-signals="{term: '', limit: 1000}">
        @GraphContainer("/api/v1/graph")
   </div> 
}