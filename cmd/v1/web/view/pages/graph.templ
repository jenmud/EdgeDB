package pages

import (
    "github.com/jenmud/edgedb/cmd/v1/web/view/layout"
	"github.com/jenmud/edgedb/cmd/v1/web/view/components"
)

templ GraphPage() {
    @layout.Base("EdgeDB") {
        @components.SearchTerm("/ui/v1/search/graph")
        <div class="divider"></div>
        @components.Graph()
    }
}